<Window x:Class="KnobConfig.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Volume Knob" Height="720" Width="400"
        Icon="knob.ico"
        MinWidth="380" ResizeMode="CanMinimize"
        FontFamily="Segoe UI" Background="{StaticResource Bg}">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- ============ header ============ -->
    <Grid Grid.Row="0" Margin="20,18,20,6">
      <StackPanel>
        <TextBlock Text="Eugene's Knob" FontSize="20" FontWeight="SemiBold"/>
        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
          <Ellipse x:Name="StatusDot" Width="9" Height="9" Fill="#FF7C7C86" VerticalAlignment="Center"/>
          <TextBlock x:Name="StatusText" Text="Disconnected" Foreground="{StaticResource TextDim}" Margin="7,0,0,0"/>
        </StackPanel>
      </StackPanel>
      <Button x:Name="ReconnectBtn" Content="Reconnect" Style="{StaticResource Ghost}"
              HorizontalAlignment="Right" VerticalAlignment="Top"/>
    </Grid>

    <!-- ============ scrollable content ============ -->
    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="20,8,20,8">
      <StackPanel>

        <!-- battery -->
        <Border Style="{StaticResource Card}">
          <StackPanel>
            <TextBlock Text="BATTERY" Style="{StaticResource Section}"/>
            <Grid x:Name="BattTrack" Height="14">
              <Border CornerRadius="7" Background="{StaticResource Track}"/>
              <Border x:Name="BattFill" CornerRadius="7" Background="{StaticResource Accent}"
                      HorizontalAlignment="Left" Width="0"/>
            </Grid>
            <TextBlock x:Name="BattText" Text="&#8212;" Margin="0,9,0,0" Foreground="{StaticResource TextDim}"/>
          </StackPanel>
        </Border>

        <!-- PC volume -->
        <Border Style="{StaticResource Card}">
          <StackPanel>
            <TextBlock Text="PC VOLUME" Style="{StaticResource Section}"/>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/>
              </Grid.ColumnDefinitions>
              <ToggleButton x:Name="MuteBtn" Grid.Column="0" Content="&#128266;" Width="34" Height="30"
                            Style="{StaticResource MuteToggle}" VerticalAlignment="Center"/>
              <Slider Grid.Column="1" x:Name="VolumeSlider" Style="{StaticResource Slider}"
                      Minimum="0" Maximum="100" Margin="12,0,0,0"/>
              <TextBlock Grid.Column="2" x:Name="VolPct" Text="&#8212;" Style="{StaticResource ValLabel}"/>
            </Grid>
          </StackPanel>
        </Border>

        <!-- LED ring -->
        <Border Style="{StaticResource Card}">
          <StackPanel>
            <TextBlock Text="LED RING" Style="{StaticResource Section}"/>

            <!-- mode segmented -->
            <Border CornerRadius="10" Background="{StaticResource Track}" Padding="3" Margin="0,0,0,4">
              <UniformGrid Rows="1" Columns="3">
                <ToggleButton x:Name="ModeRainbow" Content="Rainbow"   Style="{StaticResource Segment}" IsChecked="True"/>
                <ToggleButton x:Name="ModeSolid"   Content="Solid"     Style="{StaticResource Segment}"/>
                <ToggleButton x:Name="ModeBreathe" Content="Breathing" Style="{StaticResource Segment}"/>
              </UniformGrid>
            </Border>

            <!-- colour (solid / breathing) -->
            <StackPanel x:Name="ColorSection" Visibility="Collapsed" Margin="0,14,0,0">
              <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <TextBlock Text="Colour" Style="{StaticResource RowLabel}"/>
                <Border Grid.Column="1" x:Name="Swatch" Height="28" CornerRadius="8"
                        Background="#FF0078FF" BorderBrush="#33FFFFFF" BorderThickness="1"/>
              </Grid>
              <Grid x:Name="WheelHost" Width="182" Height="182" Background="Transparent"
                    HorizontalAlignment="Center" Margin="0,2,0,12">
                <Image x:Name="WheelImage" Width="182" Height="182"/>
                <Canvas x:Name="WheelCanvas" Width="182" Height="182" IsHitTestVisible="False">
                  <Ellipse x:Name="WheelSelector" Width="15" Height="15" Stroke="White" StrokeThickness="2">
                    <Ellipse.Effect><DropShadowEffect BlurRadius="4" ShadowDepth="0" Color="#99000000"/></Ellipse.Effect>
                  </Ellipse>
                </Canvas>
              </Grid>
              <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions><ColumnDefinition Width="50"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <TextBlock Text="Value" Style="{StaticResource RowLabel}"/>
                <Slider Grid.Column="1" x:Name="ValueSlider" Style="{StaticResource Slider}" Minimum="0" Maximum="255"/>
              </Grid>
              <WrapPanel x:Name="Presets"/>
            </StackPanel>

            <!-- brightness -->
            <Grid Margin="0,14,0,0">
              <Grid.ColumnDefinitions><ColumnDefinition Width="90"/><ColumnDefinition Width="*"/><ColumnDefinition Width="42"/></Grid.ColumnDefinitions>
              <TextBlock Text="Brightness" Style="{StaticResource RowLabel}"/>
              <Slider Grid.Column="1" x:Name="BrightnessSlider" Style="{StaticResource Slider}" Minimum="0" Maximum="255"/>
              <TextBlock Grid.Column="2" x:Name="BrightnessVal" Text="45" Style="{StaticResource ValLabel}"/>
            </Grid>
          </StackPanel>
        </Border>

        <!-- motion -->
        <Border x:Name="MotionCard" Style="{StaticResource Card}">
          <StackPanel>
            <TextBlock Text="MOTION" Style="{StaticResource Section}"/>
            <StackPanel x:Name="RainbowSection">
              <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions><ColumnDefinition Width="90"/><ColumnDefinition Width="*"/><ColumnDefinition Width="42"/></Grid.ColumnDefinitions>
                <TextBlock Text="Speed" Style="{StaticResource RowLabel}"/>
                <Slider Grid.Column="1" x:Name="SpeedSlider" Style="{StaticResource Slider}" Minimum="1" Maximum="80"/>
                <TextBlock Grid.Column="2" x:Name="SpeedVal" Text="26" Style="{StaticResource ValLabel}"/>
              </Grid>
              <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="90"/><ColumnDefinition Width="*"/><ColumnDefinition Width="42"/></Grid.ColumnDefinitions>
                <TextBlock Text="Spread" Style="{StaticResource RowLabel}"/>
                <Slider Grid.Column="1" x:Name="SpreadSlider" Style="{StaticResource Slider}" Minimum="0" Maximum="40"/>
                <TextBlock Grid.Column="2" x:Name="SpreadVal" Text="16" Style="{StaticResource ValLabel}"/>
              </Grid>
            </StackPanel>
            <StackPanel x:Name="BreatheSection" Visibility="Collapsed">
              <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="90"/><ColumnDefinition Width="*"/><ColumnDefinition Width="42"/></Grid.ColumnDefinitions>
                <TextBlock Text="Speed" Style="{StaticResource RowLabel}"/>
                <Slider Grid.Column="1" x:Name="BreatheSlider" Style="{StaticResource Slider}" Minimum="3" Maximum="40"/>
                <TextBlock Grid.Column="2" x:Name="BreatheVal" Text="14" Style="{StaticResource ValLabel}"/>
              </Grid>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- power saving -->
        <Border Style="{StaticResource Card}">
          <StackPanel>
            <TextBlock Text="POWER SAVING" Style="{StaticResource Section}"/>
            <Grid Margin="0,0,0,10">
              <Grid.ColumnDefinitions><ColumnDefinition Width="90"/><ColumnDefinition Width="*"/><ColumnDefinition Width="48"/></Grid.ColumnDefinitions>
              <TextBlock Text="Dim after" Style="{StaticResource RowLabel}"/>
              <Slider Grid.Column="1" x:Name="IdleDimSlider" Style="{StaticResource Slider}" Minimum="1" Maximum="120"/>
              <TextBlock Grid.Column="2" x:Name="IdleDimVal" Text="15 s" Style="{StaticResource ValLabel}"/>
            </Grid>
            <Grid Margin="0,0,0,10">
              <Grid.ColumnDefinitions><ColumnDefinition Width="90"/><ColumnDefinition Width="*"/><ColumnDefinition Width="48"/></Grid.ColumnDefinitions>
              <TextBlock Text="Off after" Style="{StaticResource RowLabel}"/>
              <Slider Grid.Column="1" x:Name="IdleOffSlider" Style="{StaticResource Slider}" Minimum="1" Maximum="300"/>
              <TextBlock Grid.Column="2" x:Name="IdleOffVal" Text="45 s" Style="{StaticResource ValLabel}"/>
            </Grid>
            <Grid>
              <Grid.ColumnDefinitions><ColumnDefinition Width="90"/><ColumnDefinition Width="*"/><ColumnDefinition Width="48"/></Grid.ColumnDefinitions>
              <TextBlock Text="Low batt" Style="{StaticResource RowLabel}"/>
              <Slider Grid.Column="1" x:Name="LowBattSlider" Style="{StaticResource Slider}" Minimum="3000" Maximum="4000" SmallChange="10" LargeChange="50"/>
              <TextBlock Grid.Column="2" x:Name="LowBattVal" Text="3.50V" Style="{StaticResource ValLabel}"/>
            </Grid>
          </StackPanel>
        </Border>

      </StackPanel>
    </ScrollViewer>

    <!-- ============ footer ============ -->
    <TextBlock Grid.Row="2" x:Name="HintText" Text="Changes save to the knob automatically."
               Foreground="{StaticResource TextDim}" FontSize="11" Margin="20,4,20,12"/>
  </Grid>
</Window>
